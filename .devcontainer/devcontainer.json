{
  "name": "Finance Sim Prototype",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Finance Sim App",
      "onAutoForward": "openPreview"
    }
  },
  // postCreateCommand runs once when the container is first created
  "postCreateCommand": "npm install",
  // postStartCommand runs every time the codespace is resumed —
  // installs any new packages then starts the server in the background.
  // Using nohup ensures the process survives the postStartCommand shell exiting.
  "postStartCommand": "npm install --prefer-offline && nohup npm start > /tmp/finance-sim.log 2>&1 &",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mtxr.sqliteviewer"
      ]
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
