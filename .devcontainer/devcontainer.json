{
  "name": "Finance Sim Prototype",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Finance Sim App",
      "onAutoForward": "openPreview"
    }
  },
  // postCreateCommand runs once when the container is first created
  "postCreateCommand": "npm install",
  // postStartCommand runs every time the codespace is resumed —
  // keeps node_modules in sync after a git pull that adds new packages.
  // --prefer-offline makes this very fast (< 2 s) when nothing has changed.
  "postStartCommand": "npm install --prefer-offline",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mtxr.sqliteviewer"
      ]
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
