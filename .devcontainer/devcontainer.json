{
  "name": "Finance Sim Prototype",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Finance Sim App",
      "onAutoForward": "openPreview"
    }
  },
  // postCreateCommand runs once when the container is first created
  "postCreateCommand": "npm install",
  // postStartCommand runs every time the codespace is resumed —
  // the script pulls latest code from main, installs packages, rebuilds
  // native modules, and starts the server (if not already running).
  // See .devcontainer/start.sh for details and log output.
  "postStartCommand": "bash .devcontainer/start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mtxr.sqliteviewer"
      ]
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development"
  }
}
